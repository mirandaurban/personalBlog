---
import '../../src/styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Miranda Urban',
  description = 'Apuntes y reflexiones sobre los libros que han cambiado algo en mí.',
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/png" href="/favicon.png" sizes="32x32">
  </head>
  <body>
    <nav>
      <a href="/" class="nav-logo">Miranda Urban</a>
      <button class="nav-toggle" aria-label="Menú" aria-expanded="false">
        <span></span>
        <span></span>
        <span></span>
      </button>
      <ul class="nav-links">
        <li><a href="/lecturas">Lecturas</a></li>
        <li><a href="/notas">Notas</a></li>
        <li><a href="/sobre-mi">Sobre mí</a></li>
        <li><a href="/archivo">Archivo</a></li>
        <li><a href="/suscripcion">Suscríbete</a></li>
      </ul>
    </nav>

    <slot />

    <footer>
      <p class="footer-note">Hecho con café y mucho amor · {new Date().getFullYear()}</p>
      <div class="footer-links">
        <a href="/terminos" class="footer-cc">Términos y condiciones</a>
        <a
          class="footer-cc"
          href="https://creativecommons.org/licenses/by-nc-sa/4.0/deed.es"
          target="_blank"
          rel="license noopener noreferrer">
          CC BY-NC-SA 4.0 · Miranda Urban Solano
        </a>
      </div>
    </footer>
  </body>
</html>

<style>
  /* ── NAV ── */
  nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.5rem 3rem;
    border-bottom: var(--border);
    position: sticky;
    top: 0;
    background: var(--cream);
    z-index: 100;
  }

  .nav-logo {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    text-decoration: none;
    color: var(--ink);
    flex-shrink: 0;
  }

  .nav-links {
    display: flex;
    gap: 2rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-links a {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    transition: color 0.2s;
    color: var(--ink);
    white-space: nowrap;
  }

  .nav-links a:hover { color: var(--rust); }

  .nav-toggle {
    display: none;
  }

  /* ── FOOTER ── */
  footer {
    padding: 2rem 3rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: var(--border);
    gap: 1.5rem;
  }

  .footer-note {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: rgba(28,25,23,0.4);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0;
  }

  .footer-links {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.3rem;
    text-align: right;
  }

  .footer-cc {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: rgba(28,25,23,0.4);
    text-decoration: none;
    transition: color 0.2s;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    line-height: 1.3;
  }

  .footer-cc:hover { color: var(--rust); }

  /* ─────────────────────────────
     TABLET Y MÓVIL (≤ 768px)
  ───────────────────────────── */
  @media (max-width: 768px) {

    /* Nav */
    nav {
      padding: 1.2rem 1.5rem;
      flex-wrap: wrap;
    }

    .nav-toggle {
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 5px;
      background: none;
      border: none;
      cursor: pointer;
      padding: 0.25rem;
    }

    .nav-toggle span {
      display: block;
      width: 22px;
      height: 1.5px;
      background: var(--ink);
      transition: transform 0.2s, opacity 0.2s;
      transform-origin: center;
    }

    .nav-toggle.open span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
    .nav-toggle.open span:nth-child(2) { opacity: 0; }
    .nav-toggle.open span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

    .nav-links {
      display: none;
      flex-direction: column;
      gap: 0;
      width: 100%;
      border-top: var(--border);
      margin-top: 0.75rem;
      padding-top: 0.25rem;
    }

    .nav-links.open {
      display: flex;
    }

    .nav-links li {
      border-bottom: 1px solid rgba(44,44,42,0.07);
    }

    .nav-links a {
      display: block;
      padding: 0.85rem 0;
      font-size: 0.8rem;
    }

    /* ==================== FOOTER MÓVIL ==================== */
    footer {
      flex-direction: column;
      align-items: center;  
      padding: 1.75rem 1.5rem;
      gap: 1rem;
      text-align: center;
    }

    .footer-note {
      font-size: 0.62rem;
      text-align: center;
      max-width: 100%;
    }

    .footer-links {
      align-items: center;          
      text-align: center;
      gap: 0.4rem;
    }

    .footer-cc {
      font-size: 0.62rem;
      white-space: normal;         
      text-align: center;
      max-width: 100%;
      padding: 0 10px;             
    }
  }
  /* Extra pequeño (muy móviles, ≤ 380px) */
  @media (max-width: 380px) {
    .footer-cc {
      font-size: 0.60rem;
      line-height: 1.4;
    }
  }
</style>

<script>
  const toggle = document.querySelector<HTMLButtonElement>('.nav-toggle');
  const links  = document.querySelector<HTMLElement>('.nav-links');

  toggle?.addEventListener('click', () => {
    const isOpen = links?.classList.toggle('open');
    toggle.classList.toggle('open', !!isOpen);
    toggle.setAttribute('aria-expanded', String(!!isOpen));
  });

  document.querySelectorAll('.nav-links a').forEach(a => {
    a.addEventListener('click', () => {
      links?.classList.remove('open');
      toggle?.classList.remove('open');
      toggle?.setAttribute('aria-expanded', 'false');
    });
  });
</script>
---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Ticker from '../components/Ticker.astro';
import BookCard from '../components/BookCard.astro';

const allLecturas = await getCollection('lecturas');
const allNotas    = await getCollection('notas');

const recentBooks = allLecturas
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);

const totalLibros   = allLecturas.length;
const totalAutores  = new Set(allLecturas.map(l => l.data.author)).size;
const totalEntradas = allLecturas.length + allNotas.length;

const fechas          = allLecturas.map(l => l.data.date.getTime());
const fechaMasAntigua = new Date(Math.min(...fechas));
const hoy             = new Date();
const mesesActiva     = Math.max(1, Math.round(
  (hoy.getFullYear() - fechaMasAntigua.getFullYear()) * 12 +
  (hoy.getMonth()    - fechaMasAntigua.getMonth())
));

const spineColors: Record<string, string> = {
  ficcion:   'var(--rust)',
  ensayo:    'var(--teal)',
  poesia:    'var(--lavender)',
  filosofia: 'var(--sage)',
  historia:  'var(--butter)',
  otro:      'var(--muted)',
  ciencia:   'var(--cream)',
  arte:      'var(--terracota)',
  politica:  'var(--slate)', 
  espiritualidad:'var(--mauve)',
  clasicos:  'var(--sand)',
  tecnologia:'var(--electric)', 
};
---

<BaseLayout
  title="Miranda Urban"
  description="Apuntes y reflexiones sobre los libros que han cambiado algo en mí."
>

  <section class="hero">
    <div class="hero-left">
      <div class="hero-top">
        <p class="eyebrow">✦ Un blog sobre libros y lo que nos dejan</p>
        <h1 class="hero-title">
          Leer es<br>
          <em>recordar</em><br>
          lo que aún<br>
          no viviste.
        </h1>
      </div>
      <div class="hero-bottom">
        <p class="hero-bio">
          Apuntes y reflexiones sobre los libros que han cambiado algo en mí. 
          Leer para mí es más que un pasatiempo, es descubrir nuevos mundos y 
          perspectivas, ampliar mi visión de este universo a través de ojos y 
          corazones ajenos.
        </p>
      </div>
    </div>

    <div class="hero-right">
      <div class="editorial-grid">
        <div class="ed-main">
          <img src="/images/base-layout-image-1.jpeg" alt="Spot de lectura 1" />
        </div>
        <div class="ed-side">
          <div class="ed-top">
            <img src="/images/base-layout-image-2.jpeg" alt="Biblioteca del abuelo" />
          </div>
          <div class="ed-bottom">
            <img src="/images/base-layout-image-3.jpeg" alt="Café, un pan, y leer" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <Ticker bg="var(--teal)" color="var(--cream)" />

  <section class="section">
    <div class="section-header">
      <h2 class="section-title">Lecturas recientes</h2>
      <a href="/lecturas" class="section-link">Ver todo el archivo →</a>
    </div>
    <div class="books-grid">
      {recentBooks.map((book) => (
        <BookCard
          title={book.data.title}
          author={book.data.author}
          excerpt={book.data.excerpt}
          genre={book.data.genre}
          date={book.data.date.toLocaleDateString('es-MX', { year: 'numeric', month: 'long' })}
          readYear={book.data.readYear}
          readTime={book.data.readTime}
          slug={book.id}
          spineColor={spineColors[book.data.genre]}
          coverImage={book.data.coverImage}
        />
      ))}
    </div>
  </section>

  <section class="quote-section">
    <div class="quote-mark" aria-hidden="true">"</div>
    <div class="quote-body">
      <blockquote>
        En algún lugar de un libro, hay una frase<br/>
        esperándonos para darle sentido a la existencia.
      </blockquote>
      <p class="quote-attr">— Miguel de Cervantes</p>
    </div>
  </section>

  <div class="about-strip">
    <div class="about-left">
      <p class="about-label">✦ Sobre este blog</p>
      <p class="about-text">
        Me gusta mucho leer y aprender de ello. Creo que cada libro que llega a nuestras 
        manos está destinado a cambiarnos, a hacernos crecer, y quiero compartir parte de 
        mi proceso contigo. Gracias por leer 🩷
      </p>
    </div>
    <div class="about-right">
      <div class="stats-grid">
        <div class="stat">
          <p class="stat-number">{totalLibros}</p>
          <p class="stat-label">Libros reseñados</p>
        </div>
        <div class="stat">
          <p class="stat-number">{mesesActiva}</p>
          <p class="stat-label">Meses activa</p>
        </div>
        <div class="stat">
          <p class="stat-number">{totalAutores}</p>
          <p class="stat-label">Autores explorados</p>
        </div>
        <div class="stat">
          <p class="stat-number">{totalEntradas}</p>
          <p class="stat-label">Entradas publicadas</p>
        </div>
      </div>
      <a href="/sobre-mi" class="about-cta">Leer más sobre mí →</a>
    </div>
  </div>

</BaseLayout>

<style>
  .hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    border-bottom: var(--border);
    height: 55vh; /* solo una vez */
  }
  .hero-left {
    padding: 1.75rem 3rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    border-right: var(--border);
  }
  .eyebrow {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--rust);
    margin-bottom: 0.75rem;
  }
  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 3.5vw, 3rem);
    padding-bottom: 1rem;
    line-height: 1.0;
    font-weight: 400;
    letter-spacing: -0.03em;
  }
  .hero-title em { font-style: italic; color: var(--rust); }
  .hero-bio {
    font-size: 1.05rem;
    line-height: 1.7;
    font-weight: 300;
    max-width: 38ch;
  }

  /* ── EDITORIAL GRID ── */
  .hero-right {
    position: relative;
    overflow: hidden;
    height: 100%;
  }

  .editorial-grid {
    display: grid;
    grid-template-columns: 3fr 2fr;
    height: 100%;
  }

  .ed-main {
    overflow: hidden;
    border-right: var(--border);
    height: 100%;
  }

  .ed-main img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s ease;
  }

  .ed-main:hover img {
    transform: scale(1.03);
  }

  .ed-side {
    display: grid;
    grid-template-rows: 1fr 1fr;
    height: 100%;
    overflow: hidden;
  }

  .ed-top,
  .ed-bottom {
    overflow: hidden;
    position: relative;
  }

  .ed-top {
    border-bottom: var(--border);
  }

  .ed-top img,
  .ed-bottom img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s ease;
  }

  .ed-top:hover img,
  .ed-bottom:hover img {
    transform: scale(1.03);
  }

  .section { padding: 5rem 3rem; }
  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 3rem;
    border-bottom: var(--border);
    padding-bottom: 1rem;
  }
  .section-title { font-family: var(--font-display); font-size: 2rem; font-weight: 400; }
  .section-link {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    text-decoration: none;
    color: var(--rust);
    border-bottom: 1px solid var(--rust);
    padding-bottom: 0.1rem;
  }
  .books-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));  /* Mejor que repeat(3,1fr) */
    gap: 0;
    border-top: var(--border);
    border-left: var(--border);
  }
  .quote-section {
    padding: 6rem 3rem;
    display: flex;
    align-items: center;
    gap: 3rem;
    border-top: var(--border);
    border-bottom: var(--border);
  }
  .quote-mark {
    font-family: var(--font-display);
    font-size: 12rem;
    line-height: 0.8;
    color: var(--rust);
    opacity: 0.15;
    flex-shrink: 0;
    user-select: none;
  }
  blockquote {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 2.5vw, 2rem);
    font-style: italic;
    line-height: 1.45;
    font-weight: 400;
    max-width: 50ch;
    margin-bottom: 1.5rem;
  }
  .quote-attr {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(44,44,42,0.5);
  }
  .about-strip {
    background: #2E3D48;
    color: var(--cream);
    display: grid;
    grid-template-columns: 1fr 1fr;
    border-top: var(--border);
    border-bottom: var(--border);
  }
  .about-left {
    padding: 4rem 3rem;
    border-right: 1.5px solid rgba(237,232,223,0.2);
  }
  .about-label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--lavender);
    margin-bottom: 1.5rem;
  }
  .about-text { font-size: 1.3rem; line-height: 1.7; font-weight: 300; max-width: 38ch; }
  .about-text em { font-style: italic; color: var(--butter); }
  .about-right {
    padding: 4rem 3rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }
  .stats-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; margin-bottom: 2rem; }
  .stat-number {
    font-family: var(--font-display);
    font-size: 3rem;
    font-weight: 400;
    line-height: 1;
    color: var(--butter);
  }
  .stat-label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(237,232,223,0.5);
    margin-top: 0.3rem;
  }
  .about-cta {
    display: inline-block;
    padding: 0.8rem 2rem;
    border: 1.5px solid var(--cream);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    text-decoration: none;
    color: var(--cream);
    align-self: flex-start;
    transition: background 0.2s, color 0.2s;
  }
  .about-cta:hover { background: var(--cream); color: var(--ink); }
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .eyebrow    { animation: fadeUp 0.6s ease both; }
  .hero-title { animation: fadeUp 0.6s ease 0.1s both; }
  .hero-bio   { animation: fadeUp 0.6s ease 0.2s both; }

  /* ── RESPONSIVE ── */

  @media (max-width: 1024px) {
    .hero {
      grid-template-columns: 1fr;
      height: auto; /* quita el 55vh fijo */
    }

    .hero-left {
      border-right: none;
      border-bottom: var(--border);
      padding: 2.5rem 2rem;
    }

    .hero-right {
      height: 45vw; 
    }

    .editorial-grid {
      grid-template-columns: 3fr 2fr;
      height: 100%;
    }

    .about-strip {
      grid-template-columns: 1fr;
    }

    .about-left {
      border-right: none;
      border-bottom: 1.5px solid rgba(237,232,223,0.2);
      padding-bottom: 3rem;
    }

    .about-right {
      padding-top: 3rem;
    }
  }

  @media (max-width: 640px) {
    .hero-left {
      padding: 2rem 1.5rem;
    }

    .hero-title {
      font-size: clamp(1.8rem, 6vw, 3rem);
    }

    .hero-bio {
      font-size: 0.9rem;
      max-width: 100%;
    }

    .hero-right {
      height: 90vw; 
    }

    .editorial-grid {
      grid-template-columns: 1fr;
      grid-template-rows: 1fr 1fr; 
      height: 100%;
    }

    .ed-main {
      height: 100%; 
    }

    .ed-side {
      display: grid;
      grid-template-columns: 1fr 1fr;
      grid-template-rows: 1fr;
      height: 100%;
    }

    .ed-top {
      height: 100%;
      border-bottom: none;
      border-right: var(--border);
    }

    .ed-bottom {
      height: 100%;
    }
  }
</style>
---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Ticker from '../components/Ticker.astro';
import BookCard from '../components/BookCard.astro';
import TagBadge from '../components/TagBadge.astro';

const allLecturas = await getCollection('lecturas');
const allNotas    = await getCollection('notas');

const recentBooks = allLecturas
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);

const totalLibros   = allLecturas.length;
const totalAutores  = new Set(allLecturas.map(l => l.data.author)).size;
const totalEntradas = allLecturas.length + allNotas.length;

const fechas          = allLecturas.map(l => l.data.date.getTime());
const fechaMasAntigua = new Date(Math.min(...fechas));
const hoy             = new Date();
const mesesActiva     = Math.max(1, Math.round(
  (hoy.getFullYear() - fechaMasAntigua.getFullYear()) * 12 +
  (hoy.getMonth()    - fechaMasAntigua.getMonth())
));

const spineColors: Record<string, string> = {
  ficcion:   'var(--rust)',
  ensayo:    'var(--teal)',
  poesia:    'var(--lavender)',
  filosofia: 'var(--sage)',
  historia:  'var(--butter)',
  otro:      'var(--muted)',
};
---

<BaseLayout
  title="Miranda Urban"
  description="Apuntes y reflexiones sobre los libros que han cambiado algo en mí."
>

  <section class="hero">
    <div class="hero-left">
      <div class="hero-top">
        <p class="eyebrow">✦ Un blog sobre libros y lo que nos dejan</p>
        <h1 class="hero-title">
          Leer es<br>
          <em>recordar</em><br>
          lo que aún<br>
          no viviste.
        </h1>
      </div>
      <div class="hero-bottom">
        <p class="hero-bio">
          Apuntes y reflexiones sobre los libros que han cambiado algo en mí. 
          Leer para mí es más que un pasatiempo, es descubrir nuevos mundos y 
          perspectivas, ampliar mi visión de este universo a través de ojos y 
          corazones ajenos.
        </p>
        <div class="hero-tags">
          <TagBadge genre="ficcion" />
          <TagBadge genre="ensayo" />
          <TagBadge genre="poesia" />
          <TagBadge genre="filosofia" />
          <TagBadge genre="historia" />
        </div>
      </div>
    </div>

    <div class="hero-right">
      <div class="scrapbook">
        <div class="scrap scrap-1">
          <img src="/images/base-layout-image-1.jpeg" alt="Spot de lectura 1" />
        </div>
        <div class="scrap scrap-2">
          <img src="/images/base-layout-image-2.jpeg" alt="Biblioteca del abuelo" />
        </div>
        <div class="scrap scrap-3">
          <img src="/images/base-layout-image-4.jpeg" alt="Café, un pan, y leer" />
        </div>
        <div class="scrap scrap-4">
          <img src="/images/base-layout-image-3.jpeg" alt="Spot de lectura 2" />
        </div>
        <div class="clip clip-red"></div>
        <div class="clip clip-gold"></div>
        <div class="sticker sticker-butter">2025 · {allLecturas.length} libros</div>
        <div class="sticker sticker-sage">activo desde 2026</div>
      </div>
    </div>
  </section>

  <Ticker bg="var(--teal)" color="var(--cream)" />

  <section class="section">
    <div class="section-header">
      <h2 class="section-title">Lecturas recientes</h2>
      <a href="/lecturas" class="section-link">Ver todo el archivo →</a>
    </div>
    <div class="books-grid">
      {recentBooks.map((book) => (
        <BookCard
          title={book.data.title}
          author={book.data.author}
          excerpt={book.data.excerpt}
          genre={book.data.genre}
          date={book.data.date.toLocaleDateString('es-MX', { year: 'numeric', month: 'long' })}
          readYear={book.data.readYear}
          readTime={book.data.readTime}
          slug={book.id}
          spineColor={spineColors[book.data.genre]}
          coverImage={book.data.coverImage}
        />
      ))}
    </div>
  </section>

  <section class="quote-section">
    <div class="quote-mark" aria-hidden="true">"</div>
    <div class="quote-body">
      <blockquote>
        En algún lugar de un libro, hay una frase<br/>
        esperándonos para darle sentido a la existencia.
      </blockquote>
      <p class="quote-attr">— Miguel de Cervantes</p>
    </div>
  </section>

  <div class="about-strip">
    <div class="about-left">
      <p class="about-label">✦ Sobre este blog</p>
      <p class="about-text">
        Me gusta mucho leer y aprender de ello. Creo que cada libro que llega a nuestras 
        manos está destinado a cambiarnos, a hacernos crecer, y quiero compartir parte de 
        mi proceso contigo. Gracias por leer 🩷
      </p>
    </div>
    <div class="about-right">
      <div class="stats-grid">
        <div class="stat">
          <p class="stat-number">{totalLibros}</p>
          <p class="stat-label">Libros reseñados</p>
        </div>
        <div class="stat">
          <p class="stat-number">{mesesActiva}</p>
          <p class="stat-label">Meses activa</p>
        </div>
        <div class="stat">
          <p class="stat-number">{totalAutores}</p>
          <p class="stat-label">Autores explorados</p>
        </div>
        <div class="stat">
          <p class="stat-number">{totalEntradas}</p>
          <p class="stat-label">Entradas publicadas</p>
        </div>
      </div>
      <a href="/sobre-mi" class="about-cta">Leer más sobre mí →</a>
    </div>
  </div>

</BaseLayout>

<style>
  .hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 88vh;
    border-bottom: var(--border);
  }
  .hero-left {
    padding: 4rem 3rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    border-right: var(--border);
  }
  .eyebrow {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--rust);
    margin-bottom: 1.5rem;
  }
  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(3rem, 5.5vw, 5.5rem);
    line-height: 1.0;
    font-weight: 400;
    letter-spacing: -0.03em;
  }
  .hero-title em { font-style: italic; color: var(--rust); }
  .hero-bio {
    font-size: 1.05rem;
    line-height: 1.7;
    font-weight: 300;
    max-width: 38ch;
    margin-top: 2rem;
  }
  .hero-tags { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 2.5rem; }
  .hero-right { position: relative; overflow: hidden; }
  .scrapbook  { position: relative; width: 100%; height: 100%; min-height: 500px; }
  .scrap {
    position: absolute;
    background: var(--paper);
    box-shadow: 3px 4px 10px rgba(44,44,42,0.10);
    overflow: hidden;
  }
  .scrap img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .scrap-1 { width:180px; height:220px; top:8%;  left:12%; rotate:-4deg;   z-index:3; }
  .scrap-2 { width:150px; height:190px; top:18%; left:46%; rotate:3deg;    z-index:2; }
  .scrap-3 { width:200px; height:140px; top:52%; left:8%;  rotate:1.5deg;  z-index:4; }
  .scrap-4 { width:130px; height:160px; top:58%; left:55%; rotate:-2.5deg; z-index:3; }
  .clip {
    position: absolute;
    width: 18px; height: 32px;
    border: 2.5px solid;
    border-radius: 10px 10px 0 0;
    z-index: 10;
  }
  .clip::after {
    content: '';
    position: absolute;
    top: 8px; left: 3px;
    width: 6px; height: 18px;
    border: 2.5px solid;
    border-radius: 6px 6px 0 0;
    border-color: inherit;
  }
  .clip-red  { border-color:var(--rust); top:5%;  left:20%; rotate:15deg;  }
  .clip-gold { border-color:#C4A227;     top:12%; left:50%; rotate:-10deg; }
  .sticker {
    position: absolute;
    padding: 0.4rem 0.8rem;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border: var(--border);
    z-index: 6;
  }
  .sticker-butter { background:var(--butter); bottom:14%; left:8%; rotate:2deg; }
  .sticker-sage   { background:var(--teal); color:var(--cream); border-color:var(--teal); top:6%; right:8%; rotate:-3deg; }
  .section { padding: 5rem 3rem; }
  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 3rem;
    border-bottom: var(--border);
    padding-bottom: 1rem;
  }
  .section-title { font-family: var(--font-display); font-size: 2rem; font-weight: 400; }
  .section-link {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    text-decoration: none;
    color: var(--rust);
    border-bottom: 1px solid var(--rust);
    padding-bottom: 0.1rem;
  }
  .books-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border-top: var(--border);
    border-left: var(--border);
  }
  .quote-section {
    padding: 6rem 3rem;
    display: flex;
    align-items: center;
    gap: 3rem;
    border-top: var(--border);
    border-bottom: var(--border);
  }
  .quote-mark {
    font-family: var(--font-display);
    font-size: 12rem;
    line-height: 0.8;
    color: var(--rust);
    opacity: 0.15;
    flex-shrink: 0;
    user-select: none;
  }
  blockquote {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 2.5vw, 2rem);
    font-style: italic;
    line-height: 1.45;
    font-weight: 400;
    max-width: 50ch;
    margin-bottom: 1.5rem;
  }
  .quote-attr {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(44,44,42,0.5);
  }
  .about-strip {
    background: #2E3D48;
    color: var(--cream);
    display: grid;
    grid-template-columns: 1fr 1fr;
    border-top: var(--border);
    border-bottom: var(--border);
  }
  .about-left {
    padding: 4rem 3rem;
    border-right: 1.5px solid rgba(237,232,223,0.2);
  }
  .about-label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--lavender);
    margin-bottom: 1.5rem;
  }
  .about-text { font-size: 1.3rem; line-height: 1.7; font-weight: 300; max-width: 38ch; }
  .about-text em { font-style: italic; color: var(--butter); }
  .about-right {
    padding: 4rem 3rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }
  .stats-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; margin-bottom: 2rem; }
  .stat-number {
    font-family: var(--font-display);
    font-size: 3rem;
    font-weight: 400;
    line-height: 1;
    color: var(--butter);
  }
  .stat-label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(237,232,223,0.5);
    margin-top: 0.3rem;
  }
  .about-cta {
    display: inline-block;
    padding: 0.8rem 2rem;
    border: 1.5px solid var(--cream);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    text-decoration: none;
    color: var(--cream);
    align-self: flex-start;
    transition: background 0.2s, color 0.2s;
  }
  .about-cta:hover { background: var(--cream); color: var(--ink); }
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .eyebrow    { animation: fadeUp 0.6s ease both; }
  .hero-title { animation: fadeUp 0.6s ease 0.1s both; }
  .hero-bio   { animation: fadeUp 0.6s ease 0.2s both; }
  .hero-tags  { animation: fadeUp 0.6s ease 0.3s both; }
  .scrap-1    { animation: fadeUp 0.7s ease 0.2s both; }
  .scrap-2    { animation: fadeUp 0.7s ease 0.35s both; }
  .scrap-3    { animation: fadeUp 0.7s ease 0.45s both; }
  .scrap-4    { animation: fadeUp 0.7s ease 0.55s both; }
</style>
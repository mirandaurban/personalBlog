---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import TagBadge from '../../components/TagBadge.astro';

export async function getStaticPaths() {
  const lecturas = await getCollection('lecturas');
  return lecturas.map(entry => ({
    params: { slug: entry.id },
    props:  { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, author, genre, coverImage, rating, date, readTime, excerpt, year, pages, publisher, readYear } = entry.data;

const dateFormatted = date.toLocaleDateString('es-MX', { year: 'numeric', month: 'long', day: 'numeric' });

const spineColors: Record<string, string> = {
  ficcion:   'var(--rust)',
  ensayo:    'var(--teal)',
  poesia:    'var(--lavender)',
  filosofia: 'var(--sage)',
  historia:  'var(--butter)',
  otro:      'var(--muted)',
};
---

<BaseLayout title={`${title} — Miranda Urban`} description={excerpt}>

  <!-- ── HERO EDITORIAL ── -->
  <section class="book-hero">

    <div class="hero-left">
      <p class="eyebrow">
        <a href="/lecturas" class="back-link">← Lecturas</a>
      </p>
      <h1 class="book-title">{title}</h1>
      <p class="book-author">{author}</p>
      <div class="meta-row">
        <TagBadge genre={genre} />
        {rating && (
          <span class="rating" aria-label={`${rating} de 5`}>
            {'★'.repeat(rating)}{'☆'.repeat(5 - rating)}
          </span>
        )}
      </div>
      <p class="book-excerpt">{excerpt}</p>
      <p class="post-meta">
        {readYear
          ? `Leído en ${readYear} · Publicado el ${dateFormatted} · ${readTime} de lectura`
          : `${dateFormatted} · ${readTime} de lectura`
        }
      </p>
    </div>

    <!-- Columna derecha: portada + ficha técnica -->
    <div class="hero-right">
      {coverImage ? (
        <div class="cover-wrap">
          <img src={coverImage} alt={`Portada de ${title}`} class="cover-img" />
        </div>
      ) : (
        <div class="cover-wrap cover-placeholder" style={`background:${spineColors[genre]}`}>
          <span class="cover-placeholder-title">{title}</span>
          <span class="cover-placeholder-author">{author}</span>
        </div>
      )}
      {(year || pages || publisher) && (
        <dl class="book-data">
          {year      && <><dt>Año</dt><dd>{year}</dd></>}
          {pages     && <><dt>Páginas</dt><dd>{pages}</dd></>}
          {publisher && <><dt>Editorial</dt><dd>{publisher}</dd></>}
        </dl>
      )}
    </div>

  </section>

  <!-- ── REVIEW ── -->
  <article class="review">
    <Content />
  </article>

  <!-- ── NAV ── -->
  <div class="post-nav">
    <a href="/lecturas" class="post-nav-link">← Volver a lecturas</a>
    <a href="/archivo" class="post-nav-link">Ver archivo →</a>
  </div>

</BaseLayout>

<style>
  /* ── HERO ── */
  .book-hero {
    display: grid;
    grid-template-columns: 1fr 350px;
    gap: 0;
    padding: 3.5rem 16rem;
    border-bottom: var(--border);
    align-items: start;
  }

  .hero-left {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding-left: 3rem;
    border-right: var(--border);
  }

  .eyebrow { margin-bottom: 1rem; }

  .back-link {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(44,44,42,0.4);
    text-decoration: none;
    transition: color 0.2s;
  }
  .back-link:hover { color: var(--rust); }

  .book-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 3.5vw, 3.5rem);
    font-weight: 400;
    line-height: 1.0;
    letter-spacing: -0.03em;
    margin-bottom: 0.6rem;
  }

  .book-author {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 300;
    font-style: italic;
    color: rgba(44,44,42,0.6);
    margin-bottom: 0;
  }

  .meta-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .rating {
    font-size: 0.9rem;
    letter-spacing: 0.1em;
    color: var(--butter);
  }

  .book-excerpt {
    font-size: 0.95rem;
    line-height: 1.7;
    font-weight: 300;
    max-width: 52ch;
    color: rgba(44,44,42,0.8);
    margin-bottom: 0;
  }

  .post-meta {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(44,44,42,0.35);
  }

  /* ── PORTADA ── */
  .hero-right {
    padding: 0 1.5rem 2rem 6rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    align-items: flex-start;
  }

  .cover-wrap {
    width: 150px;
    height: 222px;
    box-shadow: 6px 8px 20px rgba(44,44,42,0.15);
    border-radius: 2px;
    overflow: hidden;
    flex-shrink: 0;
  }

  .cover-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .cover-placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    padding: 1rem;
    gap: 0.4rem;
  }

  .cover-placeholder-title {
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 700;
    color: white;
    text-align: center;
    line-height: 1.2;
  }

  .cover-placeholder-author {
    font-family: var(--font-mono);
    font-size: 0.55rem;
    color: rgba(255,255,255,0.7);
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .book-data {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.3rem 1rem;
    margin-bottom: 1.5rem;
  }

  .book-data dt {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(44,44,42,0.4);
    padding-top: 0.05rem;
  }

  .book-data dd {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--ink);
  }

  /* ── REVIEW ── */
  .review {
    max-width: 700px;
    margin: 0 auto;
    padding: 5rem 3rem;
  }

  .review :global(h2) {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 400;
    letter-spacing: -0.02em;
    margin: 3rem 0 1rem;
  }

  .review :global(p) {
    font-size: 1.05rem;
    line-height: 1.8;
    font-weight: 300;
    margin-bottom: 1.4rem;
    color: rgba(44,44,42,0.9);
  }

  .review :global(blockquote) {
    border-left: 3px solid var(--rust);
    padding: 0.5rem 0 0.5rem 1.5rem;
    margin: 2rem 0;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.15rem;
    line-height: 1.6;
    color: rgba(44,44,42,0.75);
  }

  .review :global(em)     { font-style: italic; }
  .review :global(strong) { font-weight: 400; border-bottom: 1.5px solid var(--ink); }
  .review :global(hr)     { border: none; border-top: var(--border); margin: 3rem 0; }

  /* ── POST NAV ── */
  .post-nav {
    display: flex;
    justify-content: space-between;
    padding: 2rem 3rem;
    border-top: var(--border);
  }

  .post-nav-link {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    text-decoration: none;
    color: rgba(44,44,42,0.4);
    transition: color 0.2s;
  }

  .post-nav-link:hover { color: var(--rust); }

  /* ── ANIMATIONS ── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .back-link    { animation: fadeUp 0.4s ease both; }
  .book-title   { animation: fadeUp 0.5s ease 0.1s both; }
  .book-author  { animation: fadeUp 0.5s ease 0.15s both; }
  .meta-row     { animation: fadeUp 0.5s ease 0.2s both; }
  .book-excerpt { animation: fadeUp 0.5s ease 0.25s both; }
  .cover-wrap   { animation: fadeUp 0.6s ease 0.2s both; }
</style>